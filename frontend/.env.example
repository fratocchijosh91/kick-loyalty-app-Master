# Kick Loyalty Frontend Configuration Template
# Copia questo file in .env e compila con i tuoi valori

# ==================== API ====================
# Backend API URL
VITE_API_URL=http://localhost:5000/api

# In production:
# VITE_API_URL=https://api.kickloyalty.com/api

# ==================== STRIPE (Opzionale) ====================
# Stripe Publishable Key (per checkout)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ==================== ANALYTICS (Opzionale) ====================
# Google Analytics
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry (error tracking)
# VITE_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# ==================== ENVIRONMENT ====================
# Mode: development, production
# Vite auto-detects this from NODE_ENV
VITE_MODE=development

# ==================== APP ====================
# App name (per header, title, etc)
VITE_APP_NAME=Kick Loyalty

# App version
VITE_APP_VERSION=2.0.0

# ==================== NOTES ====================
# 1. VITE_API_URL:
#    - Development: http://localhost:5000/api
#    - Production: https://api.kickloyalty.com/api
#
# 2. Stripe Publishable Key:
#    - Test key starts with pk_test_
#    - Live key starts with pk_live_
#    - Get from https://dashboard.stripe.com/apikeys
#
# 3. Solo le variabili che cominciano con VITE_
#    sono esposte al client via import.meta.env
#    (Non mettere secrets qui!)
#
# 4. Environment-specific:
#    - .env                 - Usato sempre
#    - .env.local           - Locale (gitignored)
#    - .env.production.local - Produzione locale
