# Kick Loyalty Backend Configuration Template
# Copia questo file in .env e compila con i tuoi valori

# ==================== SERVER ====================
NODE_ENV=development
PORT=5000

# ==================== DATABASE ====================
# MongoDB local
MONGODB_URI=mongodb://localhost:27017/kick-loyalty

# Oppure MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kick-loyalty?retryWrites=true&w=majority

# ==================== AUTHENTICATION ====================
# JWT Secret - CAMBIA QUESTO IN PRODUZIONE!
JWT_SECRET=your-super-secret-jwt-key-that-is-at-least-32-characters-long-change-in-production

# ==================== TELEMETRY / KPI (opzionale) ====================
# Segreto per chiamate machine-to-machine (es. GitHub Actions release:check)
# TELEMETRY_ADMIN_SECRET=generate-a-long-random-string
# Lista username Kick (minuscolo) che possono leggere GET /api/telemetry/summary con JWT
# TELEMETRY_ADMIN_USERNAMES=streamer1,streamer2
# SOLO SVILUPPO: espone il summary senza auth (non usare in produzione)
# TELEMETRY_SUMMARY_OPEN=false

# Kick — OAuth dashboard (PKCE, usati da server.js)
KICK_CLIENT_ID=your_kick_oauth_client_id
KICK_CLIENT_SECRET=your_kick_oauth_client_secret
KICK_REDIRECT_URI=http://localhost:3000/auth/callback

# Legacy / altre integrazioni Kick (se usate)
# KICK_API_ID=your_kick_api_id_here
# KICK_API_SECRET=your_kick_api_secret_here

# PKCE per OAuth (generato dinamicamente, no need to set)
# PKCE_CHALLENGE_METHOD=S256

# ==================== PAYMENT (Stripe) ====================
# Segreto server (mai nel frontend): https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Opzionale sul backend (email/link); sul frontend usa VITE_STRIPE_PUBLISHABLE_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Checkout server.js: Price ID del prodotto/abbonamento (mode subscription o payment secondo il codice)
STRIPE_PRICE_ID=price_test_your_recurring_or_one_time_price
# Endpoint: POST /api/stripe/webhook — crea endpoint in Stripe Dashboard e incolla il signing secret
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# ==================== SICUREZZA EXTRA ====================
# 2FA: stringa lunga casuale (openssl rand -hex 32). Obbligatoria in produzione se usi 2FA.
# ENCRYPTION_KEY=

# Solo staging: consente POST /api/auth/login con solo username (NON per produzione pubblica)
# ALLOW_USERNAME_LOGIN=true

# ==================== EMAIL SERVICE ====================
# Provider: gmail, sendgrid, mailgun
EMAIL_PROVIDER=gmail

# Gmail Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_specific_password

# SendGrid Configuration (alternative to Gmail)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Mailgun Configuration (alternative to Gmail)
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_domain.mailgun.org

# ==================== FRONTEND ====================
# Frontend URL (usato nei link nelle email e webhook)
FRONTEND_URL=http://localhost:5173

# ==================== AI ====================
# Groq API Key (per AI chat proxy)
GROQ_API_KEY=your_groq_api_key_here

# ==================== LOGGING ====================
LOG_LEVEL=info
# Options: debug, info, warn, error

# ==================== CORS ====================
# Allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== OPTIONAL: ERROR TRACKING ====================
# Sentry (error tracking)
# SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# ==================== OPTIONAL: MONITORING ====================
# Datadog (monitoring and metrics)
# DATADOG_API_KEY=your_datadog_api_key

# ==================== OPTIONAL: AWS S3 (File Storage) ====================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=kick-loyalty-uploads

# ==================== SMS NOTIFICATIONS (Phase 2.6) ====================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
SMS_VERIFICATION_CODE_EXPIRY=600000
SMS_DEFAULT_DAILY_LIMIT=10
SMS_DEFAULT_WEEKLY_LIMIT=50

# Alternative: AWS SNS
# SMS_PROVIDER=aws-sns
# AWS_SNS_REGION=us-east-1

# ==================== PDF EXPORT (Phase 3) ====================
# Puppeteer/Chromium executable path (auto-detected if not set)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ==================== WEBHOOK SECURITY (Phase 4) ====================
# Webhook signature secret (for verifying incoming webhooks)
WEBHOOK_SIGNATURE_SECRET=your_webhook_signature_secret_for_verification

# ==================== PUSH NOTIFICATIONS (Phase 5) ====================
# VAPID Keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ==================== PRODUCTION SETTINGS ====================
# Trust proxy (required for Railway/Render/Heroku)
TRUST_PROXY=true

# Compression
ENABLE_COMPRESSION=true

# ==================== NOTES ====================
# 1. Gmail App Password:
#    - Abilita 2FA su https://myaccount.google.com/security
#    - Genera App Password su https://myaccount.google.com/apppasswords
#    - Copia la password (senza spazi)
#
# 2. Stripe Test Mode:
#    - Usa sk_test_* e pk_test_* per testing
#    - Non usare chiavi live () in development
#
# 3. JWT Secret:
#    - Genera con: openssl rand -base64 32
#    - Minimum 32 characters
#    - DEVE essere diverso in produzione
#
# 4. MongoDB:
#    - Local: mongodb://localhost:27017/kick-loyalty
#    - Atlas: mongodb+srv://user:pass@cluster.mongodb.net/db
#
# 5. Kick API:
#    - Registrati su https://dev.kick.com/
#    - Crea application per ottenere credentials
#
# 6. Email Provider:
#    - Gmail: per development/testing
#    - SendGrid: per production (consigliato)
#    - Mailgun: alternativa production
