# Kick Loyalty Backend Configuration Template
# Copia questo file in .env e compila con i tuoi valori

# ==================== SERVER ====================
NODE_ENV=development
PORT=5000

# ==================== DATABASE ====================
# MongoDB local
MONGODB_URI=mongodb://localhost:27017/kick-loyalty

# Oppure MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kick-loyalty?retryWrites=true&w=majority

# ==================== AUTHENTICATION ====================
# JWT Secret - CAMBIA QUESTO IN PRODUZIONE!
JWT_SECRET=your-super-secret-jwt-key-that-is-at-least-32-characters-long-change-in-production

# Kick API Credentials
KICK_API_ID=your_kick_api_id_here
KICK_API_SECRET=your_kick_api_secret_here

# PKCE per OAuth (generato dinamicamente, no need to set)
# PKCE_CHALLENGE_METHOD=S256

# ==================== PAYMENT ====================
# Stripe Test Keys (sk_test_*, pk_test_*)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret (per webhook verification)
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# ==================== EMAIL SERVICE ====================
# Provider: gmail, sendgrid, mailgun
EMAIL_PROVIDER=gmail

# Gmail Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_specific_password

# SendGrid Configuration (alternative to Gmail)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Mailgun Configuration (alternative to Gmail)
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_domain.mailgun.org

# ==================== FRONTEND ====================
# Frontend URL (usato nei link nelle email e webhook)
FRONTEND_URL=http://localhost:5173

# ==================== AI ====================
# Groq API Key (per AI chat proxy)
GROQ_API_KEY=your_groq_api_key_here

# ==================== LOGGING ====================
LOG_LEVEL=info
# Options: debug, info, warn, error

# ==================== CORS ====================
# Allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== OPTIONAL: ERROR TRACKING ====================
# Sentry (error tracking)
# SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id

# ==================== OPTIONAL: MONITORING ====================
# Datadog (monitoring and metrics)
# DATADOG_API_KEY=your_datadog_api_key

# ==================== OPTIONAL: AWS S3 (File Storage) ====================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=kick-loyalty-uploads

# ==================== NOTES ====================
# 1. Gmail App Password:
#    - Abilita 2FA su https://myaccount.google.com/security
#    - Genera App Password su https://myaccount.google.com/apppasswords
#    - Copia la password (senza spazi)
#
# 2. Stripe Test Mode:
#    - Usa sk_test_* e pk_test_* per testing
#    - Non usare chiavi live () in development
#
# 3. JWT Secret:
#    - Genera con: openssl rand -base64 32
#    - Minimum 32 characters
#    - DEVE essere diverso in produzione
#
# 4. MongoDB:
#    - Local: mongodb://localhost:27017/kick-loyalty
#    - Atlas: mongodb+srv://user:pass@cluster.mongodb.net/db
#
# 5. Kick API:
#    - Registrati su https://dev.kick.com/
#    - Crea application per ottenere credentials
#
# 6. Email Provider:
#    - Gmail: per development/testing
#    - SendGrid: per production (consigliato)
#    - Mailgun: alternativa production
